<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Pin a single source so Central Package Management doesn't need source mapping
       (and so the build is hermetic regardless of the machine's global NuGet feeds). -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
